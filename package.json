{
  "name": "morphling-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "test": "node --test",
    "test:container": "node scripts/test-video-container.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --enable-containers",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@auth/core": "0.41.2",
    "@cloudflare/containers": "0.3.7",
    "@convex-dev/auth": "0.0.94",
    "convex": "1.42.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "6.17.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "wrangler": "4.107.0"
  }
}
